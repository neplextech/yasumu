{
  "nodeModulesDir": "manual",
  "unstable": ["sloppy-imports"],
  "links": [
    "../../packages/common",
    "../../packages/rpc",
    "../../packages/core",
    "../../packages/den",
    "../../packages/schema",
    "../../packages/echo-server",
    "../../packages/workspace-importer",
    "../../packages/sync",
  ],
  "imports": {
    "@/": "./src/",
    "yasumu:types": "../../crates/tanxium/src/runtime/bootstrap.ts",
  },
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
  },
}
