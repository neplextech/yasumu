{
  "name": "@yasumu/tanxium",
  "version": "0.0.0",
  "private": true,
  "description": "JavaScript source for Yasumu's Tanxium JavaScript runtime",
  "license": "AGPL-3.0",
  "author": "Neplex",
  "repository": {
    "type": "git",
    "url": "https://github.com/neplextech/yasumu.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./headless/persistence": "./src/headless/persistence/index.ts",
    "./headless/platform": "./src/headless/platform/index.ts",
    "./headless/runtime": "./src/headless/runtime/index.ts"
  },
  "scripts": {
    "build": "deno task bundle",
    "deno": "deno",
    "dev": "deno run -A ./test/main.ts",
    "bundle": "deno task generate-schema && deno --allow-write --allow-read --unstable-bundle scripts/bundle.ts",
    "drizzle:generate": "deno task generate-schema && drizzle-kit generate",
    "migrate": "deno task generate-schema && drizzle-kit generate",
    "studio": "deno task generate-schema && drizzle-kit studio",
    "generate-schema": "deno --allow-read --allow-write ./scripts/generate-schema.ts",
    "check:persistence": "tsc --project src/headless/persistence/tsconfig.json",
    "check:platform": "tsc --project src/headless/platform/tsconfig.json",
    "test:persistence": "deno test --no-check --allow-read src/headless/persistence/*.test.ts",
    "test:platform": "deno test --no-check --allow-read --allow-write src/headless/platform/*.test.ts",
    "lint": "deno lint"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@yasumu/common": "file:../../packages/common",
    "@yasumu/core": "file:../../packages/core",
    "@yasumu/den": "file:../../packages/den",
    "@yasumu/echo-server": "file:../../packages/echo-server",
    "@yasumu/headless": "file:../../packages/headless",
    "@yasumu/rpc": "file:../../packages/rpc",
    "@yasumu/runtime-api": "file:../../packages/runtime-api",
    "@yasumu/schema": "file:../../packages/schema",
    "@yasumu/sync": "file:../../packages/sync",
    "@yasumu/workspace-importer": "file:../../packages/workspace-importer",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "mailparser": "^3.9.8",
    "smtp-server": "^3.18.4",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.6.2",
    "@types/smtp-server": "^3.5.13",
    "typescript": "catalog:build"
  }
}
