{
  "name": "yasumu",
  "version": "0.0.1",
  "description": "Command Line Interface for Yasumu",
  "license": "AGPL-3.0",
  "author": "Neplex",
  "repository": {
    "type": "git",
    "url": "https://github.com/neplextech/yasumu.git"
  },
  "bin": {
    "yasumu": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "pnpm --filter @yasumu/schema build && pnpm --filter @yasumu/runtime-api build && pnpm --filter @yasumu/headless build && pnpm --filter @yasumu/runtime-node build && pnpm --filter @yasumu/echo-server build && pnpm build && pnpm typecheck:test && vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@yasumu/echo-server": "workspace:*",
    "@yasumu/headless": "workspace:*",
    "@yasumu/runtime-api": "workspace:*",
    "@yasumu/runtime-node": "workspace:*",
    "@yasumu/schema": "workspace:*",
    "commander": "^14.0.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "catalog:build",
    "@yasumu/shared": "workspace:*",
    "@yasumu/tsconfig": "workspace:*",
    "typescript": "catalog:build",
    "vitest": "catalog:test"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
