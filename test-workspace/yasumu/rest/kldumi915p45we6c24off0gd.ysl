@rest

metadata {
  name: "Get Rauchg's GitHub Profile"
  method: "GET"
  id: "kldumi915p45we6c24off0gd"
  groupId: "mv2z3sr80ai1cv2axxap3juq"
}

request {
  url: "https://api.github.com/users/rauchg"
  headers: []
  parameters: []
  searchParameters: []
  body: null
}

dependencies []

script {
  interface IGithubUser {
    followers: number;
    name: string;
  }

  let rauchg: IGithubUser | null = null;

  export async function onRequest(_ctx: RequestHookContext) {
    if (rauchg) return new Response(JSON.stringify(rauchg));
  }

  export async function onResponse(ctx: ResponseHookContext) {
    const body = await ctx.res.json() as IGithubUser;
    if (rauchg) rauchg = body;

    await Yasumu.ui.showNotification({
      title: 'GitHub Profile Fetched',
      message: `${body.name} has ${body.followers.toLocaleString()} followers count on github.`,
      variant: 'info',
    });

    ctx.workspace.env.setVariable('FOLLOWER_COUNT', body.followers.toString())
  }
}
